<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@styles/styles.css"
            fx:controller="com.dhruvijain.deliveryplanner.controller.DashboardController">

    <!-- ─── Top Bar ─────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="topbar">
            <Label text="Delivery Planner" styleClass="topbar-title"/>
            <Label fx:id="roleLabel" text="Role:" styleClass="topbar-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Download Report"
                    onAction="#handleDownloadReport"
                    styleClass="btn-success"/>
            <Button text="Logout"
                    onAction="#handleLogout"
                    styleClass="btn-danger"/>
        </HBox>
    </top>

    <!-- ─── Center (Deliveries + Map) ───────────────────────────── -->
    <center>
        <SplitPane dividerPositions="0.48"
                   orientation="VERTICAL"
                   styleClass="dash-body">

            <!-- ── Deliveries panel ── -->
            <VBox spacing="14" style="-fx-padding: 16 16 12 16; -fx-background-color: #f1f5f9;">
                <VBox spacing="12" styleClass="panel" VBox.vgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Deliveries" styleClass="section-title"/>
                            <Label text="All active delivery requests" styleClass="section-caption"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchAddressField"
                                   promptText="Search address..."
                                   styleClass="search-field"
                                   prefWidth="240"/>
                        <ComboBox fx:id="filterStatusCombo"
                                  promptText="Status"
                                  styleClass="dash-combo"
                                  prefWidth="130"/>
                    </HBox>

                    <TableView fx:id="deliveriesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idCol"        text="ID"        prefWidth="50"/>
                            <TableColumn fx:id="addressCol"   text="ADDRESS"   prefWidth="320"/>
                            <TableColumn fx:id="statusCol"    text="STATUS"    prefWidth="110"/>
                            <TableColumn fx:id="driverIdCol"  text="DRIVER"    prefWidth="80"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="addressField"
                                   promptText="Address"
                                   styleClass="dash-input"
                                   HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="driverIdField"
                                   promptText="Driver ID"
                                   styleClass="dash-input"
                                   prefWidth="100"/>
                        <Button text="Add Delivery"
                                onAction="#handleAddDelivery"
                                styleClass="btn-primary"/>
                        <Button text="Simulate Transit"
                                onAction="#handleSimulateTransit"
                                styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ── Map panel ── -->
            <VBox style="-fx-padding: 4 16 16 16; -fx-background-color: #f1f5f9;">
                <VBox styleClass="panel, panel-map" VBox.vgrow="ALWAYS">
                    <Label text="ROUTING MAP · select a delivery to focus" styleClass="map-header"/>
                    <WebView fx:id="mapWebView" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>
        </SplitPane>
    </center>

    <!-- ─── Drivers (Admin) sidebar ─────────────────────────────── -->
    <right>
        <VBox fx:id="driverAdminPanel"
              spacing="12"
              prefWidth="320"
              style="-fx-padding: 16 16 16 0; -fx-background-color: #f1f5f9;">
            <VBox spacing="12" styleClass="panel" VBox.vgrow="ALWAYS">
                <VBox>
                    <Label text="Drivers" styleClass="section-title"/>
                    <Label text="Admin-only fleet management" styleClass="section-caption"/>
                </VBox>
                <TableView fx:id="driversTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="driverIdColTb"     text="ID"       prefWidth="40"/>
                        <TableColumn fx:id="driverNameCol"     text="NAME"     prefWidth="100"/>
                        <TableColumn fx:id="driverContactCol"  text="CONTACT"  prefWidth="110"/>
                        <TableColumn fx:id="driverLicenseCol"  text="LICENSE"  prefWidth="90"/>
                    </columns>
                </TableView>
                <VBox spacing="8">
                    <TextField fx:id="driverNameField"    promptText="Driver name"     styleClass="dash-input"/>
                    <TextField fx:id="driverContactField" promptText="Contact (+91 …)" styleClass="dash-input"/>
                    <TextField fx:id="driverLicenseField" promptText="License number"  styleClass="dash-input"/>
                    <Button fx:id="addDriverButton"
                            text="+  Add Driver"
                            onAction="#handleAddDriver"
                            styleClass="btn-primary, btn-full"/>
                </VBox>
            </VBox>
        </VBox>
    </right>
</BorderPane>
